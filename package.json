{
  "name": "mysource",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node -e \"const f='dist/server/wrangler.json';const d=JSON.parse(require('fs').readFileSync(f,'utf8'));if(d.assets&&d.assets.binding==='ASSETS'){d.assets.binding='SITE_ASSETS'}require('fs').writeFileSync(f,JSON.stringify(d))\"",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.6",
    "@astrojs/react": "^5.0.2",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@keystatic/astro": "^5.0.6",
    "@keystatic/core": "^0.5.50",
    "astro": "^6.1.2",
    "astro-seo": "^1.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "wrangler": "^4.80.0"
  }
}
