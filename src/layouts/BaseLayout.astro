---
import SEOHead from '../components/SEOHead.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  schemas?: Array<{ type: 'organization' | 'website' | 'service' | 'course' | 'article' | 'faq' | 'breadcrumb'; data?: Record<string, unknown> }>;
}

const { title, description, ogImage, ogType, noindex, schemas = [] } = Astro.props;
const currentPath = Astro.url.pathname;

// Always include Organization and WebSite schemas on every page
const defaultSchemas: typeof schemas = [
  { type: 'organization' },
  { type: 'website' },
];

const allSchemas = [...defaultSchemas, ...schemas];
---

<!doctype html>
<html lang="pl" dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="format-detection" content="telephone=no" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/images/apple-touch-icon.png" />

    <!-- Fonts: Adobe Typekit (Degular Text + Nocturne Serif + Nocturne Serif Lights) -->
    <link rel="preconnect" href="https://use.typekit.net" crossorigin />
    <link rel="stylesheet" href="https://use.typekit.net/hmd2hoe.css" />

    <!-- Google Fonts: Inconsolata -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inconsolata:wght@400;700&display=swap"
    />

    <SEOHead
      title={title}
      description={description}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
    />

    <!-- Schema.org JSON-LD -->
    {allSchemas.map((s) => (
      <SchemaOrg type={s.type} data={s.data} />
    ))}

    <!-- Google Analytics (GA4) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-J6Q1HWPK67"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-J6Q1HWPK67');
    </script>
  </head>

  <body>
    <a href="#main-content" class="sr-only">Przejdź do treści głównej</a>

    <Header currentPath={currentPath} />

    <main id="main-content">
      <slot />
    </main>

    <Footer />
    <ScrollReveal />
  </body>
</html>
