---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import Newsletter from '../components/Newsletter.astro';

const faqs = [
  {
    q: 'Co to jest mysource?',
    a: 'Mysource to strategiczny partner transformacji organizacyjnej, który łączy dobrostan ludzi z pragmatyką biznesu w kontekście zmian technologicznych. Wdrażamy programy rozwojowe w wymiarach wellbeingu, przywództwa i kompetencji przyszłości.',
  },
  {
    q: 'Co znajdę w mysource?',
    a: 'Oferujemy rozwiązania dla firm w dwóch obszarach: budowanie kultury organizacyjnej poprzez programy dla zespołów i liderów oparte na autorskich ścieżkach rozwojowych oraz Wellbeing Branding dla relacji biznesowych.',
  },
  {
    q: 'Do kogo skierowana jest oferta mysource?',
    a: 'Głównie do klienta biznesowego — firm i organizacji. Współorganizujemy również wydarzenia dla klientów indywidualnych, o których informujemy na naszym Instagramie.',
  },
  {
    q: 'Jak mam wybrać najlepsze rozwiązanie dla swojej organizacji?',
    a: 'Oferujemy indywidualne i bezpłatne konsultacje oraz szeroki asortyment narzędzi analitycznych, które pomagają dostosować program do potrzeb i budżetu organizacji.',
  },
  {
    q: 'Jakie są wymierne korzyści dla organizacji?',
    a: 'Redukcja stresu i absencji, wzrost zaangażowania pracowników, zwiększenie kreatywności i innowacyjności, lepsza adaptacja technologiczna oraz efekty employer brandingowe i ESG.',
  },
  {
    q: 'Jaki jest koszt programu?',
    a: 'Każda oferta mysource jest spersonalizowana i dostosowywana do potrzeb danego klienta. Szczegóły dostępne są przez kontakt indywidualny.',
  },
  {
    q: 'Czego się mogę spodziewać podczas wydarzenia?',
    a: 'Nasze wydarzenia łączą psychoedukację z wielozmysłowym i sensorycznym doświadczaniem. Programy projektujemy indywidualnie dla każdego klienta.',
  },
  {
    q: 'Jakich ekspertów znajdę w mysource?',
    a: 'Mysource to stale rosnąca społeczność ekspertów i specjalistów metod i praktyk rozwojowych — kuratorów i praktyków z różnych dziedzin.',
  },
  {
    q: 'Czy oferta skierowana jest tylko do pracowników?',
    a: 'Nie. Tworzymy programy dla całej struktury organizacji oraz jej otoczenia: pracowników, liderów, zarządów i klientów biznesowych.',
  },
  {
    q: 'Czy ścieżki można łączyć?',
    a: 'Tak, ścieżki można dowolnie łączyć i dostosowywać do potrzeb organizacji.',
  },
  {
    q: 'Gdzie odbywają się wydarzenia?',
    a: 'W 300m² przestrzeni rozwojowej na terenie warszawskiego Konesera, w siedzibie firmy klienta lub w formie programów wyjazdowych.',
  },
  {
    q: 'Jaka jest skala i czas trwania projektów?',
    a: 'Projekty są indywidualnie dopasowane — od power speeches po kompleksową, długofalową strategię transformacji.',
  },
  {
    q: 'Czy program ścieżek jest zestandaryzowany?',
    a: 'Nie. Konkretny scenariusz ścieżki przygotowujemy indywidualnie dla klienta, uwzględniając potrzeby, harmonogram i budżet.',
  },
  {
    q: 'Czy prowadzimy usługi w języku angielskim?',
    a: 'Tak, posiadamy ofertę dedykowaną anglojęzycznym zespołom.',
  },
  {
    q: 'Jak mogę się zapisać do newslettera?',
    a: 'Formularz zapisu na newsletter znajdziesz w sekcji kontaktu na naszej stronie lub na dole każdej podstrony.',
  },
];

const schemas = [
  {
    type: 'breadcrumb' as const,
    data: {
      items: [
        { name: 'Strona główna', url: 'https://www.mysource.pl/' },
        { name: 'FAQ', url: 'https://www.mysource.pl/faq' },
      ],
    },
  },
  {
    type: 'faq' as const,
    data: {
      questions: faqs.map((f) => ({ question: f.q, answer: f.a })),
    },
  },
];
---

<BaseLayout
  title="FAQ — Najczęściej zadawane pytania | Mysource"
  description="Odpowiedzi na najczęściej zadawane pytania o mysource, nasze programy rozwojowe, ścieżki szkoleniowe i współpracę."
  schemas={schemas}
>
  <!-- ════════ HERO ════════ -->
  <section class="faq-hero">
    <div class="container container--wide">
      <span class="label" data-reveal="none">Pomoc</span>
      <h1 class="faq-hero__title" data-reveal-words data-reveal-delay="100">
        Najczęściej zadawane pytania
      </h1>
    </div>
  </section>

  <!-- ════════ FAQ ════════ -->
  <section class="faq-section">
    <div class="container container--wide">
      <div class="faq__list">
        {faqs.map((faq, i) => (
          <details class="faq__item" data-reveal data-reveal-delay={String(i * 50)}>
            <summary class="faq__question">
              <span class="faq__question-text">{faq.q}</span>
              <span class="faq__icon" aria-hidden="true">+</span>
            </summary>
            <div class="faq__answer">
              <p>{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════ CTA ════════ -->
  <CTA variant="cream" />

  <!-- ════════ NEWSLETTER ════════ -->
  <Newsletter variant="sand" />
</BaseLayout>

<style>
  .faq-hero {
    padding-top: var(--space-5xl);
    padding-bottom: var(--space-4xl);
    background-color: var(--cream);
  }

  .faq-hero__title {
    font-size: var(--text-5xl);
    font-family: var(--font-display-light);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.03em;
    max-width: 16ch;
  }

  /* ─── FAQ list ─── */
  .faq__list {
    max-width: 800px;
  }

  .faq__item {
    border-bottom: 1px solid var(--sand);
    padding: var(--space-lg) 0;
  }

  .faq__question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    list-style: none;
    gap: var(--space-lg);
  }

  .faq__question::-webkit-details-marker {
    display: none;
  }

  .faq__question-text {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 400;
    line-height: 1.3;
  }

  .faq__icon {
    font-size: var(--text-2xl);
    font-weight: 300;
    color: var(--grey);
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .faq__item[open] .faq__icon {
    transform: rotate(45deg);
  }

  .faq__answer {
    padding-top: var(--space-md);
    padding-right: var(--space-3xl);
    color: var(--grey);
    line-height: 1.8;
    font-size: var(--text-base);
  }

  @media (max-width: 768px) {
    .faq__answer {
      padding-right: 0;
    }
  }
</style>
