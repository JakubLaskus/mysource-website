---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import Newsletter from '../components/Newsletter.astro';
import ReportBanner from '../components/ReportBanner.astro';
import { founders } from '../data/team';

const schemas = [
  {
    type: 'service' as const,
    data: {
      '@id': 'https://www.mysource.pl/#lab',
      name: 'Mysource LAB - Szkolenia i warsztaty',
      description: 'Szkolenia i warsztaty dla pracowników i liderów. Wellbeing, transformacja technologiczna, przywództwo.',
      serviceType: 'Training',
      url: 'https://www.mysource.pl/oferta',
    },
  },
  {
    type: 'service' as const,
    data: {
      '@id': 'https://www.mysource.pl/#ai-readiness',
      name: 'AI Readiness - RADAR diagnostyka transformacji AI',
      description: 'Kompleksowe narzędzie diagnostyczne badające gotowość organizacji do transformacji AI z perspektywy ludzi.',
      serviceType: 'Consulting',
      url: 'https://www.mysource.pl/o-nas',
    },
  },
];
---

<BaseLayout
  title="Mysource — Ludzki wymiar transformacji technologicznej"
  description="Przygotowujemy organizacje na przyszłość poprzez budowanie ludzkiej gotowości: fizycznej, psychicznej i poznawczej. Szkolenia, diagnostyka AI RADAR, programy wellbeingowe."
  schemas={schemas}
>
  <!-- ════════ REPORT BANNER ════════ -->
  <ReportBanner />

  <!-- ════════ HERO ════════ -->
  <section class="hero">
    <div class="container container--wide">
      <span class="hero__label label" data-reveal="none">mysource</span>
      <h1 class="hero__title" data-reveal-words data-reveal-delay="100">
        Przygotowujemy organizacje na przyszłość poprzez budowanie <em>ludzkiej gotowości</em>: fizycznej, psychicznej i poznawczej
      </h1>
      <p class="hero__lead" data-reveal data-reveal-delay="400">
        Ludzki wymiar transformacji technologicznej.
      </p>
      <div class="hero__scroll-hint scroll-indicator" data-reveal="none" data-reveal-delay="800">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 13l5 5 5-5M7 6l5 5 5-5"/></svg>
      </div>
    </div>
    <!-- Full-bleed video/animation slot -->
    <div class="hero__media" data-reveal>
      <video class="hero__video" autoplay muted loop playsinline poster="/images/photos/team-photo.jpg" src="https://cdn.prod.website-files.com/66aa6a4241e2b2382ff3a79b%2F67990446b15b73b11162be7b_426_MY_SOURCE_SHORT_online_15_01_2025_1080p_eug_38_web-transcode.mp4"></video>
    </div>
  </section>

  <!-- ════════ MANIFESTO ════════ -->
  <section class="manifesto">
    <div class="container container--wide">
      <div class="manifesto__grid">
        <div class="manifesto__left" data-reveal="left">
          <span class="label">Idea</span>
        </div>
        <div class="manifesto__right">
          <div class="reveal-clip">
            <p class="manifesto__statement font-display" data-reveal="clip-up">
              W świecie, gdzie każda firma ma dostęp do tych samych narzędzi AI, przewagę konkurencyjną daje gotowość ludzi do współpracy z technologią.
            </p>
          </div>
          <div data-reveal-line data-reveal-delay="300" style="margin: var(--space-xl) 0; color: var(--ink);"></div>
          <p class="manifesto__sub" data-reveal data-reveal-delay="400">
            Dobrostan to nie cel — to fundament, na którym budujemy gotowość ludzi do transformacji.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ SERVICES ════════ -->
  <section class="services" id="uslugi">
    <div class="container container--wide">
      <div class="services__header">
        <span class="label" data-reveal="left">Co robimy</span>
        <h2 class="services__title" data-reveal-words data-reveal-delay="100">Dwa obszary. Jeden cel.</h2>
      </div>

      <div class="services__grid">
        <!-- LAB -->
        <div class="services__item">
          <div class="services__item-meta" data-reveal="left">
            <span class="services__number font-mono" data-reveal-counter="1" data-counter-suffix="" style="min-width:2ch;">0</span>
            <span class="label" style="color: var(--sage-dark);">LAB</span>
          </div>
          <div class="services__item-content">
            <div class="reveal-clip"><h3 class="services__item-title" data-reveal="clip-up">Szkolenia i warsztaty dla pracowników i liderów</h3></div>
            <p class="services__item-desc" data-reveal data-reveal-delay="150">
              Stawiamy człowieka w centrum organizacji. Nasze szkolenia podzieliliśmy na trzy kluczowe obszary — wellbeing, transformacja technologiczna i przywództwo.
            </p>
            <div class="services__tags" data-reveal-stagger>
              <span class="tag tag--sage">Wellbeing</span>
              <span class="tag tag--ember">Transformacja</span>
              <span class="tag tag--mist">Liderzy</span>
            </div>
            <a href="/oferta" class="btn btn--ghost" data-reveal data-reveal-delay="300">Poznaj ofertę szkoleń</a>
          </div>
        </div>

        <!-- AI READINESS -->
        <div class="services__item">
          <div class="services__item-meta" data-reveal="left">
            <span class="services__number font-mono" data-reveal-counter="2" data-counter-suffix="" style="min-width:2ch;">0</span>
            <span class="label" style="color: var(--ember);">AI Readiness</span>
          </div>
          <div class="services__item-content">
            <div class="reveal-clip"><h3 class="services__item-title" data-reveal="clip-up">Diagnostyka transformacji AI</h3></div>
            <p class="services__item-desc" data-reveal data-reveal-delay="150">
              RADAR to kompleksowe narzędzie diagnostyczne, które bada gotowość organizacji do transformacji AI z perspektywy ludzi — pracowników, zespołów i kultury organizacyjnej.
            </p>
            <div class="services__tags" data-reveal-stagger>
              <span class="tag tag--ember">RADAR</span>
            </div>
            <a href="/o-nas" class="btn btn--ghost" data-reveal data-reveal-delay="300">Dowiedz się więcej</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ STATEMENT (dark) ════════ -->
  <section class="statement">
    <figure class="statement__quote">
      <div class="statement__portrait">
        <img src="/images/team/gosia.jpg" alt="Gosia — Mysource" loading="lazy" />
      </div>
      <blockquote class="statement__text" data-reveal>
        Transformacja technologiczna zaczyna się od ludzi.
      </blockquote>
    </figure>
  </section>

  <!-- ════════ CTA ════════ -->
  <CTA variant="ember" />

  <!-- ════════ MISJA + FOUNDERS ════════ -->
  <section class="misja">
    <div class="container container--wide">
      <div class="misja__grid">
        <div class="misja__left" data-reveal="left">
          <span class="label">Misja</span>
        </div>
        <div class="misja__right">
          <div class="reveal-clip">
            <p class="misja__text font-display" data-reveal="clip-up">
              Jesteśmy kompasem dla firm, które chcą bezpiecznie i świadomie przepłynąć przez fale współczesnych transformacji.
            </p>
          </div>
          <div data-reveal-line data-reveal-delay="200" style="margin: var(--space-xl) 0; color: var(--ink);"></div>
          <p class="misja__sub" data-reveal data-reveal-delay="300">
            Wierzymy, że kluczem do sukcesu jest połączenie siły człowieka z mądrym wykorzystaniem sztucznej inteligencji. Kompleksowo troszczymy się o rozwój liderów i pracowników.
          </p>
        </div>
      </div>

      <div data-reveal-line style="color: var(--sand); margin-bottom: var(--space-3xl);"></div>

    </div>
  </section>

  <!-- ════════ PARTNERS ════════ -->
  <section class="partners" id="partnerzy">
    <div class="container container--wide">
      <span class="label" data-reveal="left">Partnerzy i eksperci</span>
      <h2 class="partners__title" data-reveal>Ludzie, którzy tworzą mysource</h2>
    </div>
    <div class="partners__track">
      {[
        { name: 'dr Iwo Zmyślony', role: 'Projektant zmiany i kultury innowacji', img: 'https://cdn.prod.website-files.com/66aa6a4241e2b2382ff3a79b/684afe6e590d434aa09ac4e7_Projekt%20bez%20nazwy%20(89).png' },
        { name: 'Adam Kowalewski', role: 'Psycholog, biohacker', img: 'https://cdn.prod.website-files.com/66aa6a4241e2b2382ff3a79b/66aa6a4241e2b2382ff3a870_kowalewski_nb_512.png' },
        { name: 'Zuzanna Ziomecka', role: 'Dziennikarka, trenerka redukcji stresu', img: 'https://cdn.prod.website-files.com/66aa6a4241e2b2382ff3a79b/66aa6a4241e2b2382ff3a872_ziomecka_nb_512.png' },
        { name: 'Julian Dworak', role: 'Coach przywództwa i zmiany', img: 'https://cdn.prod.website-files.com/66aa6a4241e2b2382ff3a79b/673f004151a3208730ed4c08_Wype%C5%82nienie%20kolorem%205512.png' },
        { name: 'Jakub Mauricz', role: 'Dietetyk, ekspert żywienia', img: 'https://cdn.prod.website-files.com/66aa6a4241e2b2382ff3a79b/66aa6a4241e2b2382ff3a86f_mauricz_nb_512.png' },
        { name: 'Mila Orlińska', role: 'Ekspertka trenowania umysłu, iMIND', img: 'https://cdn.prod.website-files.com/66aa6a4241e2b2382ff3a79b/66e884df080060a11a4f6672_mila_orlinska_512.png' },
        { name: 'Piotr Matejuk', role: 'Hipnoterapeuta, doktorant PAN', img: 'https://cdn.prod.website-files.com/66aa6a4241e2b2382ff3a79b/66e884df9589e58c0c0ea7dc_matejuk_1024.png' },
        { name: 'Dorota Szczepan-Jakubowska', role: 'Psycholożka biznesu, grupa TROP', img: 'https://cdn.prod.website-files.com/66aa6a4241e2b2382ff3a79b/673eff8f9fb51c650f6d7e47_dorota_szj.png' },
        { name: 'Filip Dębowski', role: 'Technohumanista, psychologia × technologia', img: 'https://cdn.prod.website-files.com/66aa6a4241e2b2382ff3a79b/6973f563a5f6f7d103440924_Filip%20De%CC%A8bowski.png' },
        { name: 'lek. med. Elżbieta Dudzińska', role: 'Terapie oddechowe, Metoda Buteyko', img: 'https://cdn.prod.website-files.com/66aa6a4241e2b2382ff3a79b/673f0043c40da38d8b055bb7_Warstwa%2022512.png' },
        { name: 'dr Asia Kubiakowska', role: 'Praca somatyczna, oddech i uważność', img: 'https://cdn.prod.website-files.com/66aa6a4241e2b2382ff3a79b/673f121c47c93ea062a75f96_Wype%C5%82nienie%20kolorem%205%20kopia%202512.png' },
        { name: 'Kalina Pieczyńska', role: 'Trenerka kompetencji interpersonalnych', img: 'https://cdn.prod.website-files.com/66aa6a4241e2b2382ff3a79b/66aa6a4241e2b2382ff3a86e_pieczynska_nb_512.png' },
        { name: 'Edyta Maksimowicz', role: 'Autorka metody Facemovement', img: 'https://cdn.prod.website-files.com/66aa6a4241e2b2382ff3a79b/673f121b5f3bb2d0e8367f8d_Warstwa%2022%20kopia512.png' },
        { name: 'Linda Parys', role: 'Trenerka kreatywności, LEGO® SERIOUS PLAY®', img: 'https://cdn.prod.website-files.com/66aa6a4241e2b2382ff3a79b/67565e7adf4c47e4272504a4_lindaparys512.png' },
        { name: 'Olga Sochanek', role: 'Trenerka oddechu, PSYCHEDELIC BREATH®', img: 'https://cdn.prod.website-files.com/66aa6a4241e2b2382ff3a79b/673f150ba4ec25576531d46f_Wype%C5%82nienie%20kolorem%205%20kopia512.png' },
      ].map((p) => (
        <div class="partner-card">
          <img src={p.img} alt={p.name} class="partner-card__img" loading="lazy" width="280" height="280" />
          <p class="partner-card__name">{p.name}</p>
          <p class="partner-card__role">{p.role}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ════════ NEWSLETTER ════════ -->
  <Newsletter variant="sand" />
</BaseLayout>

<style>
  /* ─── Hero ─── */
  .hero {
    padding-top: var(--space-4xl);
    padding-bottom: 0;
    background-color: var(--cream);
    position: relative;
  }

  .hero__label {
    display: block;
    margin-bottom: var(--space-lg);
    color: var(--grey);
    font-size: var(--text-sm);
  }

  .hero__media {
    width: 100%;
    aspect-ratio: 21 / 9;
    overflow: hidden;
    background-color: var(--ink);
    margin-top: var(--space-3xl);
  }

  .hero__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero__title {
    font-family: var(--font-display-light);
    font-size: var(--text-5xl);
    font-weight: 400;
    letter-spacing: -0.035em;
    line-height: 1.1;
    color: var(--ink);
    max-width: 28ch;
    margin-bottom: var(--space-2xl);
  }

  .hero__lead {
    font-size: var(--text-lg);
    line-height: 1.6;
    color: var(--grey);
    max-width: 42ch;
  }

  .hero__scroll-hint {
    margin-top: var(--space-2xl);
    color: var(--grey);
    opacity: 0.5;
  }

  /* ─── Manifesto ─── */
  .manifesto {
    padding-block: var(--space-5xl);
    background-color: var(--white);
  }

  .manifesto__grid {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  .manifesto__left {
    padding-top: var(--space-xs);
  }

  .manifesto__statement {
    font-size: var(--text-3xl);
    font-weight: 400;
    line-height: 1.35;
    max-width: none;
    margin-top: 0;
  }

  .manifesto__sub {
    font-size: var(--text-lg);
    line-height: 1.8;
    color: var(--grey);
    max-width: 50ch;
  }

  /* ─── Services ─── */
  .services {
    padding-block: var(--space-5xl);
    background-color: var(--cream);
  }

  .services__header {
    margin-bottom: var(--space-4xl);
  }

  .services__title {
    font-size: var(--text-4xl);
    margin-top: var(--space-md);
    line-height: 1.15;
  }

  .services__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    align-items: stretch;
  }

  .services__item {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    padding-block: var(--space-xl);
    background: transparent;
    border: none;
    border-radius: 0;
  }

  .services__item-meta {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid rgba(26, 26, 25, 0.08);
  }

  .services__number {
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--sand);
    line-height: 1;
  }

  .services__item-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    flex: 1;
  }

  .services__item-title {
    font-size: var(--text-3xl);
    line-height: 1.15;
    margin-bottom: var(--space-sm);
  }

  .services__item-desc {
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--grey);
    max-width: none;
    flex-grow: 1;
  }

  .services__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
  }

  .services__item .btn--ghost {
    margin-top: auto;
    align-self: flex-start;
  }

  .services__divider {
    height: 1px;
    background: currentColor;
  }

  /* ─── Statement (dark) ─── */
  .statement {
    background-color: var(--deep);
    padding: 0;
  }

  .statement__quote {
    position: relative;
    margin: 0;
    min-height: clamp(360px, 55vh, 580px);
    overflow: hidden;
    background-color: var(--cream);
  }

  .statement__portrait {
    position: absolute;
    inset: 0;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
  }

  .statement__portrait img {
    width: auto;
    height: 100%;
    max-width: 55%;
    object-fit: contain;
    object-position: left bottom;
    display: block;
  }

  .statement__text {
    position: absolute;
    right: clamp(2rem, 8vw, 6rem);
    bottom: clamp(2rem, 6vw, 4rem);
    max-width: min(36ch, 42vw);
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.4vw, 2.25rem);
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.01em;
    line-height: 1.3;
    color: var(--ink);
    margin: 0;
    text-transform: none;
  }

  @media (max-width: 768px) {
    .statement__quote {
      min-height: 40vh;
    }
    .statement__text {
      left: var(--content-padding);
      right: var(--content-padding);
      bottom: var(--space-xl);
      max-width: none;
      font-size: var(--text-xl);
    }
  }

  /* ─── Misja ─── */
  .misja {
    padding-block: var(--space-5xl);
    background-color: var(--white);
  }

  .misja__grid {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: var(--space-3xl);
    align-items: start;
    margin-bottom: var(--space-4xl);
  }

  .misja__left {
    padding-top: var(--space-xs);
  }

  .misja__text {
    font-size: var(--text-3xl);
    font-weight: 400;
    line-height: 1.35;
    max-width: none;
  }

  .misja__sub {
    font-size: var(--text-lg);
    line-height: 1.8;
    color: var(--grey);
    max-width: 50ch;
  }

  .misja__founders {
    display: flex;
    gap: var(--space-3xl);
  }

  .misja__person {
    text-align: left;
  }

  .misja__avatar {
    width: 144px;
    height: 144px;
    border-radius: var(--radius-full);
    background: var(--sand-light);
    margin-bottom: var(--space-md);
    object-fit: cover;
  }

  .misja__person-name {
    font-weight: 400;
    font-size: var(--text-base);
    margin-bottom: var(--space-xs);
  }

  .misja__person-role {
    font-size: var(--text-sm);
  }

  /* ─── Partners ─── */
  .partners {
    padding-block: var(--space-5xl);
    background-color: var(--cream);
    overflow: hidden;
  }

  .partners__title {
    font-size: var(--text-3xl);
    margin-top: var(--space-md);
    margin-bottom: var(--space-3xl);
  }

  .partners__track {
    display: flex;
    gap: var(--space-xl);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding: 0 var(--content-padding) var(--space-xl);
    scrollbar-width: none;
  }

  .partners__track::-webkit-scrollbar {
    display: none;
  }

  .partner-card {
    flex: 0 0 240px;
    scroll-snap-align: start;
  }

  .partner-card__img {
    width: 240px;
    height: 240px;
    border-radius: var(--radius-md);
    object-fit: cover;
    background: var(--sand-light);
    margin-bottom: var(--space-md);
  }

  .partner-card__name {
    font-size: var(--text-sm);
    font-weight: 400;
    line-height: 1.3;
  }

  .partner-card__role {
    font-size: var(--text-xs);
    color: var(--grey);
    line-height: 1.5;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: var(--space-xs);
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .hero__title {
      font-size: var(--text-5xl);
    }

    .manifesto__grid,
    .misja__grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .services__grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .services__item {
      padding-block: var(--space-md);
    }

    .services__item-title {
      font-size: var(--text-2xl);
    }

    .misja__founders {
      flex-direction: column;
      gap: var(--space-xl);
    }

    .partner-card {
      flex: 0 0 200px;
    }

    .partner-card__img {
      width: 200px;
      height: 200px;
    }
  }
</style>
