---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import Newsletter from '../components/Newsletter.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CornerBrackets from '../components/CornerBrackets.astro';
import EditorialQuote from '../components/EditorialQuote.astro';
import { founders } from '../data/team';
import { pathCategories } from '../data/paths';

const schemas = [
  {
    type: 'service' as const,
    data: {
      '@id': 'https://www.mysource.pl/#lab',
      name: 'Mysource LAB - Szkolenia i warsztaty',
      description: 'Szkolenia i warsztaty dla pracowników i liderów. Wellbeing, transformacja technologiczna, przywództwo.',
      serviceType: 'Training',
      url: 'https://www.mysource.pl/oferta',
    },
  },
  {
    type: 'service' as const,
    data: {
      '@id': 'https://www.mysource.pl/#ai-readiness',
      name: 'AI Readiness - RADAR diagnostyka transformacji AI',
      description: 'Kompleksowe narzędzie diagnostyczne badające gotowość organizacji do transformacji AI z perspektywy ludzi.',
      serviceType: 'Consulting',
      url: 'https://www.mysource.pl/o-nas',
    },
  },
];
---

<BaseLayout
  title="Mysource — Ludzki wymiar transformacji technologicznej"
  description="Przygotowujemy organizacje na przyszłość poprzez budowanie ludzkiej gotowości: fizycznej, psychicznej i poznawczej. Szkolenia, diagnostyka AI RADAR, programy wellbeingowe."
  schemas={schemas}
>
  <!-- ════════ HERO (full-bleed video) ════════ -->
  <section class="hero section--photo">
    <video class="hero__video" autoplay muted loop playsinline poster="/images/photos/team-photo.jpg" src="https://cdn.prod.website-files.com/66aa6a4241e2b2382ff3a79b%2F67990446b15b73b11162be7b_426_MY_SOURCE_SHORT_online_15_01_2025_1080p_eug_38_web-transcode.mp4"></video>
    <div class="hero__overlay"></div>
    <CornerBrackets />
    <div class="container container--editorial hero__content">
      <span class="hero__label label" data-reveal="none">mysource</span>
      <h1 class="hero__title" data-reveal-words data-reveal-delay="100">
        Ludzki wymiar transformacji technologicznej
      </h1>
      <p class="hero__lead" data-reveal data-reveal-delay="400">
        Przygotowujemy organizacje na przyszłość poprzez budowanie ludzkiej gotowości — fizycznej, psychicznej i poznawczej.
      </p>
      <div class="hero__scroll-hint" data-reveal="none" data-reveal-delay="800">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 13l5 5 5-5M7 6l5 5 5-5"/></svg>
      </div>
    </div>
  </section>

  <!-- ════════ MANIFESTO ════════ -->
  <section class="manifesto">
    <div class="container container--wide">
      <SectionHeader label="Idea" number="01" variant="light" />
      <div class="editorial-grid">
        <div></div>
        <div>
          <EditorialQuote variant="light">
            <p class="manifesto__statement font-display" data-reveal="clip-up">
              W świecie, gdzie każda firma ma dostęp do tych samych narzędzi AI, przewagę konkurencyjną daje gotowość ludzi do współpracy z technologią.
            </p>
          </EditorialQuote>
          <div data-reveal-line data-reveal-delay="300" style="margin: var(--space-xl) 0; color: var(--ink);"></div>
          <p class="manifesto__sub" data-reveal data-reveal-delay="400">
            Dobrostan to nie cel — to fundament, na którym budujemy gotowość ludzi do transformacji.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ SERVICES (dark) ════════ -->
  <section class="services" id="uslugi">
    <div class="container container--wide">
      <SectionHeader label="Co robimy" number="02" variant="dark" />
      <h2 class="services__title" data-reveal-words data-reveal-delay="100">Dwa obszary. Jeden cel.</h2>

      <div class="services__cards">
        <!-- LAB + ŚCIEŻKI -->
        <div class="services__card services__card--lab glass-card" data-reveal data-reveal-delay="200">
          <div class="services__card-top">
            <span class="services__number font-mono" data-reveal-counter="1" data-counter-suffix="" style="min-width:2ch;">0</span>
            <span class="services__card-label">LAB</span>
          </div>
          <h3 class="services__card-title">Szkolenia i warsztaty dla pracowników i liderów</h3>
          <p class="services__card-desc">
            Stawiamy człowieka w centrum organizacji. Nasze szkolenia podzieliliśmy na trzy kluczowe obszary.
          </p>
          <div class="services__paths">
            {pathCategories.map((cat) => (
              <a href={`/oferta#${cat.id}`} class="services__path-link" data-reveal data-reveal-delay="300">
                <span class="services__path-number font-mono">{cat.number}</span>
                <div>
                  <span class="services__path-title">{cat.title}</span>
                  <span class="services__path-sub">{cat.subtitle}</span>
                </div>
              </a>
            ))}
          </div>
          <a href="/oferta" class="btn btn--ghost btn--ghost-light">Poznaj wszystkie ścieżki</a>
        </div>

        <!-- AI READINESS -->
        <div class="services__card glass-card" data-reveal data-reveal-delay="350">
          <div class="services__card-top">
            <span class="services__number font-mono" data-reveal-counter="2" data-counter-suffix="" style="min-width:2ch;">0</span>
            <span class="services__card-label">AI Readiness</span>
          </div>
          <h3 class="services__card-title">Diagnostyka transformacji AI</h3>
          <p class="services__card-desc">
            RADAR to kompleksowe narzędzie diagnostyczne, które bada gotowość organizacji do transformacji AI z perspektywy ludzi — pracowników, zespołów i kultury organizacyjnej.
          </p>
          <div class="services__tags">
            <span class="tag tag--ember">RADAR</span>
          </div>
          <a href="/o-nas" class="btn btn--ghost btn--ghost-light">Dowiedz się więcej</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ STATEMENT (photo + brackets) ════════ -->
  <section class="statement section--photo">
    <img src="/images/photos/team-photo.jpg" alt="" class="statement__bg" aria-hidden="true" />
    <div class="statement__overlay"></div>
    <CornerBrackets />
    <div class="container container--wide statement__content">
      <EditorialQuote variant="dark">
        <h2 class="statement__text" data-reveal-words>
          Transformacja technologiczna zaczyna się od ludzi.
        </h2>
      </EditorialQuote>
    </div>
  </section>

  <!-- ════════ CTA ════════ -->
  <section class="cta-section">
    <div class="container container--wide">
      <SectionHeader label="Kontakt" number="03" variant="light" />
    </div>
    <CTA variant="cream" />
  </section>

  <!-- ════════ MISJA ════════ -->
  <section class="misja">
    <div class="container container--wide">
      <SectionHeader label="Misja" number="04" variant="light" />
      <div class="editorial-grid">
        <div></div>
        <div>
          <EditorialQuote variant="light">
            <p class="misja__text font-display" data-reveal="clip-up">
              Jesteśmy kompasem dla firm, które chcą bezpiecznie i świadomie przepłynąć przez fale współczesnych transformacji.
            </p>
          </EditorialQuote>
          <div data-reveal-line data-reveal-delay="200" style="margin: var(--space-xl) 0; color: var(--ink);"></div>
          <p class="misja__sub" data-reveal data-reveal-delay="300">
            Wierzymy, że kluczem do sukcesu jest połączenie siły człowieka z mądrym wykorzystaniem sztucznej inteligencji. Kompleksowo troszczymy się o rozwój liderów i pracowników.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ PARTNERS (dark) ════════ -->
  <section class="partners" id="partnerzy">
    <div class="container container--wide">
      <SectionHeader label="Partnerzy i eksperci" number="05" variant="dark" />
      <h2 class="partners__title" data-reveal>Ludzie, którzy tworzą mysource</h2>
    </div>
    <div class="partners__track">
      {[
        { name: 'dr Iwo Zmyślony', role: 'Projektant zmiany i kultury innowacji', img: 'https://cdn.prod.website-files.com/66aa6a4241e2b2382ff3a79b/684afe6e590d434aa09ac4e7_Projekt%20bez%20nazwy%20(89).png' },
        { name: 'Adam Kowalewski', role: 'Psycholog, biohacker', img: 'https://cdn.prod.website-files.com/66aa6a4241e2b2382ff3a79b/66aa6a4241e2b2382ff3a870_kowalewski_nb_512.png' },
        { name: 'Zuzanna Ziomecka', role: 'Dziennikarka, trenerka redukcji stresu', img: 'https://cdn.prod.website-files.com/66aa6a4241e2b2382ff3a79b/66aa6a4241e2b2382ff3a872_ziomecka_nb_512.png' },
        { name: 'Julian Dworak', role: 'Coach przywództwa i zmiany', img: 'https://cdn.prod.website-files.com/66aa6a4241e2b2382ff3a79b/673f004151a3208730ed4c08_Wype%C5%82nienie%20kolorem%205512.png' },
        { name: 'Jakub Mauricz', role: 'Dietetyk, ekspert żywienia', img: 'https://cdn.prod.website-files.com/66aa6a4241e2b2382ff3a79b/66aa6a4241e2b2382ff3a86f_mauricz_nb_512.png' },
        { name: 'Mila Orlińska', role: 'Ekspertka trenowania umysłu, iMIND', img: 'https://cdn.prod.website-files.com/66aa6a4241e2b2382ff3a79b/66e884df080060a11a4f6672_mila_orlinska_512.png' },
        { name: 'Piotr Matejuk', role: 'Hipnoterapeuta, doktorant PAN', img: 'https://cdn.prod.website-files.com/66aa6a4241e2b2382ff3a79b/66e884df9589e58c0c0ea7dc_matejuk_1024.png' },
        { name: 'Dorota Szczepan-Jakubowska', role: 'Psycholożka biznesu, grupa TROP', img: 'https://cdn.prod.website-files.com/66aa6a4241e2b2382ff3a79b/673eff8f9fb51c650f6d7e47_dorota_szj.png' },
        { name: 'Filip Dębowski', role: 'Technohumanista, psychologia × technologia', img: 'https://cdn.prod.website-files.com/66aa6a4241e2b2382ff3a79b/6973f563a5f6f7d103440924_Filip%20De%CC%A8bowski.png' },
        { name: 'lek. med. Elżbieta Dudzińska', role: 'Terapie oddechowe, Metoda Buteyko', img: 'https://cdn.prod.website-files.com/66aa6a4241e2b2382ff3a79b/673f0043c40da38d8b055bb7_Warstwa%2022512.png' },
        { name: 'dr Asia Kubiakowska', role: 'Praca somatyczna, oddech i uważność', img: 'https://cdn.prod.website-files.com/66aa6a4241e2b2382ff3a79b/673f121c47c93ea062a75f96_Wype%C5%82nienie%20kolorem%205%20kopia%202512.png' },
        { name: 'Kalina Pieczyńska', role: 'Trenerka kompetencji interpersonalnych', img: 'https://cdn.prod.website-files.com/66aa6a4241e2b2382ff3a79b/66aa6a4241e2b2382ff3a86e_pieczynska_nb_512.png' },
        { name: 'Edyta Maksimowicz', role: 'Autorka metody Facemovement', img: 'https://cdn.prod.website-files.com/66aa6a4241e2b2382ff3a79b/673f121b5f3bb2d0e8367f8d_Warstwa%2022%20kopia512.png' },
        { name: 'Linda Parys', role: 'Trenerka kreatywności, LEGO® SERIOUS PLAY®', img: 'https://cdn.prod.website-files.com/66aa6a4241e2b2382ff3a79b/67565e7adf4c47e4272504a4_lindaparys512.png' },
        { name: 'Olga Sochanek', role: 'Trenerka oddechu, PSYCHEDELIC BREATH®', img: 'https://cdn.prod.website-files.com/66aa6a4241e2b2382ff3a79b/673f150ba4ec25576531d46f_Wype%C5%82nienie%20kolorem%205%20kopia512.png' },
      ].map((p) => (
        <div class="partner-card">
          <img src={p.img} alt={p.name} class="partner-card__img" loading="lazy" width="280" height="280" />
          <p class="partner-card__name">{p.name}</p>
          <p class="partner-card__role">{p.role}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ════════ NEWSLETTER ════════ -->
  <section class="newsletter-section">
    <div class="container container--wide">
      <SectionHeader label="Newsletter" number="06" variant="light" />
    </div>
    <Newsletter variant="sand" />
  </section>
</BaseLayout>

<style>
  /* ─── Hero (full-bleed video) ─── */
  .hero {
    min-height: 90vh;
    display: flex;
    align-items: flex-end;
    background-color: var(--deep);
  }

  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(10, 22, 40, 0.25) 0%,
      rgba(10, 22, 40, 0.5) 60%,
      rgba(10, 22, 40, 0.8) 100%
    );
    z-index: 1;
  }

  .hero__content {
    position: relative;
    z-index: 3;
    padding-bottom: var(--space-5xl);
    padding-top: var(--space-5xl);
  }

  .hero__label {
    display: block;
    margin-bottom: var(--space-lg);
    color: rgba(255, 255, 255, 0.5);
    font-size: var(--text-sm);
  }

  .hero__title {
    font-family: var(--font-display-light);
    font-size: var(--text-7xl);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.0;
    color: var(--white);
    max-width: 14ch;
    margin-bottom: var(--space-2xl);
  }

  .hero__lead {
    font-size: var(--text-lg);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
    max-width: 42ch;
  }

  .hero__scroll-hint {
    margin-top: var(--space-2xl);
    color: rgba(255, 255, 255, 0.4);
  }

  /* ─── Manifesto ─── */
  .manifesto {
    padding-block: var(--space-5xl);
    background-color: var(--white);
  }

  .manifesto__statement {
    font-size: var(--text-4xl);
    font-weight: 600;
    line-height: 1.3;
    max-width: none;
    margin-top: 0;
  }

  .manifesto__sub {
    font-size: var(--text-lg);
    line-height: 1.8;
    color: var(--grey);
    max-width: 50ch;
  }

  /* ─── Services (dark) ─── */
  .services {
    padding-block: var(--space-5xl);
    background-color: var(--deep);
    color: var(--white);
  }

  .services__title {
    font-size: var(--text-4xl);
    margin-top: var(--space-lg);
    margin-bottom: var(--space-4xl);
    line-height: 1.15;
    color: var(--white);
  }

  .services__cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
  }

  .services__card {
    padding: var(--space-3xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .services__card-top {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
  }

  .services__number {
    font-size: var(--text-4xl);
    font-weight: 700;
    color: var(--sand);
    line-height: 1;
  }

  .services__card-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--ember);
  }

  .services__card-title {
    font-size: var(--text-3xl);
    line-height: 1.2;
    color: var(--white);
  }

  .services__card-desc {
    font-size: var(--text-base);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.6);
    max-width: 45ch;
  }

  .services__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .services .tag {
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .services__paths {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-sm);
  }

  .services__path-link {
    display: flex;
    gap: var(--space-sm);
    padding: var(--space-md);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-sm);
    transition: border-color 0.3s, background-color 0.3s;
    align-items: flex-start;
  }

  .services__path-link:hover {
    border-color: rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.03);
  }

  .services__path-number {
    font-size: var(--text-xs);
    color: var(--sand);
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .services__path-title {
    display: block;
    font-size: var(--text-base);
    color: var(--white);
    font-weight: 500;
    line-height: 1.3;
  }

  .services__path-sub {
    display: block;
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.45);
    margin-top: var(--space-xs);
    line-height: 1.4;
  }

  .btn--ghost-light {
    color: rgba(255, 255, 255, 0.8);
  }

  .btn--ghost-light:hover {
    color: var(--white);
    border-bottom-color: var(--white);
  }

  /* ─── Statement (photo + brackets) ─── */
  .statement {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--deep);
  }

  .statement__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .statement__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(10, 22, 40, 0.55),
      rgba(10, 22, 40, 0.75)
    );
    z-index: 1;
  }

  .statement__content {
    position: relative;
    z-index: 3;
    padding-block: var(--space-5xl);
  }

  .statement__text {
    font-family: var(--font-display-light);
    font-size: var(--text-6xl);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--white);
    max-width: 18ch;
    margin-inline: auto;
    text-align: center;
  }

  /* ─── CTA section ─── */
  .cta-section {
    background-color: var(--cream);
    padding-top: var(--space-4xl);
  }

  /* ─── Misja ─── */
  .misja {
    padding-block: var(--space-5xl);
    background-color: var(--white);
  }

  .misja__text {
    font-size: var(--text-3xl);
    font-weight: 500;
    line-height: 1.35;
    max-width: none;
  }

  .misja__sub {
    font-size: var(--text-lg);
    line-height: 1.8;
    color: var(--grey);
    max-width: 50ch;
  }

  /* ─── Partners (dark) ─── */
  .partners {
    padding-block: var(--space-5xl);
    background-color: var(--deep);
    color: var(--white);
    overflow: hidden;
  }

  .partners__title {
    font-size: var(--text-3xl);
    margin-top: var(--space-md);
    margin-bottom: var(--space-3xl);
    color: var(--white);
  }

  .partners__track {
    display: flex;
    gap: var(--space-xl);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding: 0 var(--content-padding) var(--space-xl);
    scrollbar-width: none;
  }

  .partners__track::-webkit-scrollbar {
    display: none;
  }

  .partner-card {
    flex: 0 0 240px;
    scroll-snap-align: start;
  }

  .partner-card__img {
    width: 240px;
    height: 240px;
    border-radius: var(--radius-md);
    object-fit: cover;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--glass-border);
    margin-bottom: var(--space-md);
  }

  .partner-card__name {
    font-size: var(--text-sm);
    font-weight: 400;
    line-height: 1.3;
    color: var(--white);
  }

  .partner-card__role {
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.5;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: var(--space-xs);
  }

  /* ─── Newsletter section ─── */
  .newsletter-section {
    background-color: var(--sand-light);
    padding-top: var(--space-4xl);
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .hero {
      min-height: 70vh;
    }

    .hero__title {
      font-size: var(--text-5xl);
    }

    .services__cards {
      grid-template-columns: 1fr;
    }

    .services__card {
      padding: var(--space-xl);
    }


    .statement {
      min-height: 50vh;
    }

    .statement__text {
      font-size: var(--text-5xl);
    }

    .partner-card {
      flex: 0 0 200px;
    }

    .partner-card__img {
      width: 200px;
      height: 200px;
    }
  }
</style>
