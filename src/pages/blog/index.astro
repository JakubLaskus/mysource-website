---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const schemas = [
  {
    type: 'breadcrumb' as const,
    data: {
      items: [
        { name: 'Strona główna', url: 'https://www.mysource.pl/' },
        { name: 'Insights', url: 'https://www.mysource.pl/blog' },
      ],
    },
  },
];
---

<BaseLayout
  title="Insights - Blog o transformacji organizacji"
  description="Artykuły, analizy i refleksje o transformacji organizacyjnej, AI readiness, wellbeingu i przywództwie w erze zmian technologicznych."
  schemas={schemas}
>
  <section class="section blog-hero">
    <div class="container">
      <p class="uppercase font-mono text-muted">Insights</p>
      <h1>Myśli o transformacji, technologii i ludziach</h1>
      <p class="blog-hero__desc">
        Dzielimy się wiedzą, obserwacjami i narzędziami, które pomagają organizacjom nawigować w świecie zmian.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {posts.length === 0 ? (
        <div class="blog-empty">
          <p class="text-muted">Wkrótce pojawią się tutaj artykuły. Zapisz się do newslettera, aby nie przegapić pierwszych publikacji.</p>
        </div>
      ) : (
        <div class="blog-grid">
          {posts.map((post) => (
            <article class="blog-card card">
              {post.data.coverImage && (
                <img
                  src={post.data.coverImage}
                  alt={post.data.title}
                  class="blog-card__image"
                  loading="lazy"
                  width="600"
                  height="340"
                />
              )}
              <div class="blog-card__content">
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="blog-card__tags">
                    {post.data.tags.slice(0, 2).map((tag: string) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
                <h2 class="blog-card__title">
                  <a href={`/blog/${post.id}`}>{post.data.title}</a>
                </h2>
                <p class="blog-card__excerpt text-muted">{post.data.excerpt}</p>
                <time class="blog-card__date font-mono text-muted" datetime={post.data.date}>
                  {new Date(post.data.date).toLocaleDateString('pl-PL', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .blog-hero {
    padding-block: var(--space-5xl) var(--space-2xl);
  }

  .blog-hero h1 {
    font-size: var(--text-4xl);
    max-width: 18ch;
    margin-top: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .blog-hero__desc {
    font-size: var(--text-lg);
    color: var(--grey);
    max-width: 55ch;
  }

  .blog-empty {
    padding: var(--space-4xl);
    text-align: center;
    background: var(--grey-light);
    border-radius: var(--radius-md);
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
  }

  .blog-card {
    overflow: hidden;
    padding: 0;
  }

  .blog-card__image {
    width: 100%;
    height: 220px;
    object-fit: cover;
  }

  .blog-card__content {
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .blog-card__tags {
    display: flex;
    gap: var(--space-sm);
  }

  .blog-card__title {
    font-size: var(--text-xl);
  }

  .blog-card__title a:hover {
    color: var(--black-hover);
  }

  .blog-card__excerpt {
    font-size: var(--text-sm);
    line-height: 1.6;
  }

  .blog-card__date {
    font-size: var(--text-xs);
    margin-top: var(--space-sm);
  }

  @media (max-width: 768px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
