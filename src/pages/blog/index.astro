---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const schemas = [
  {
    type: 'breadcrumb' as const,
    data: {
      items: [
        { name: 'Strona główna', url: 'https://www.mysource.pl/' },
        { name: 'Insights', url: 'https://www.mysource.pl/blog' },
      ],
    },
  },
];
---

<BaseLayout
  title="Insights - Blog o transformacji organizacji"
  description="Artykuły, analizy i refleksje o transformacji organizacyjnej, AI readiness, wellbeingu i przywództwie w erze zmian technologicznych."
  schemas={schemas}
>
  <!-- ════════ HERO ════════ -->
  <section class="blog-hero">
    <div class="container container--wide">
      <SectionHeader label="Insights" variant="light" />
      <h1 class="blog-hero__title" data-reveal-words data-reveal-delay="100">
        Myśli o transformacji, technologii i ludziach
      </h1>
      <p class="blog-hero__desc" data-reveal data-reveal-delay="250">
        Dzielimy się wiedzą, obserwacjami i narzędziami, które pomagają organizacjom nawigować w świecie zmian.
      </p>
    </div>
  </section>

  <!-- ════════ POSTS ════════ -->
  <section class="blog-posts">
    <div class="container container--wide">
      <SectionHeader label="Artykuły" number="01" variant="dark" />
      {posts.length === 0 ? (
        <div class="blog-empty glass-card">
          <p>Wkrótce pojawią się tutaj artykuły. Zapisz się do newslettera, aby nie przegapić pierwszych publikacji.</p>
        </div>
      ) : (
        <div class="blog-grid">
          {posts.map((post) => (
            <article class="blog-card glass-card" data-reveal>
              {post.data.coverImage && (
                <img
                  src={post.data.coverImage}
                  alt={post.data.title}
                  class="blog-card__image"
                  loading="lazy"
                  width="600"
                  height="340"
                />
              )}
              <div class="blog-card__content">
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="blog-card__tags">
                    {post.data.tags.slice(0, 2).map((tag: string) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
                <h2 class="blog-card__title">
                  <a href={`/blog/${post.id}`}>{post.data.title}</a>
                </h2>
                <p class="blog-card__excerpt">{post.data.excerpt}</p>
                <time class="blog-card__date font-mono" datetime={post.data.date}>
                  {new Date(post.data.date).toLocaleDateString('pl-PL', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  /* ─── Hero ─── */
  .blog-hero {
    padding-top: var(--space-5xl);
    padding-bottom: var(--space-4xl);
    background-color: var(--cream);
  }

  .blog-hero__title {
    font-size: var(--text-6xl);
    font-family: var(--font-display-light);
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 1.0;
    max-width: 18ch;
    margin-bottom: var(--space-xl);
  }

  .blog-hero__desc {
    font-size: var(--text-xl);
    color: var(--grey);
    max-width: 55ch;
    line-height: 1.6;
  }

  /* ─── Posts (dark) ─── */
  .blog-posts {
    padding-block: var(--space-5xl);
    background-color: var(--deep);
    color: var(--white);
  }

  .blog-empty {
    padding: var(--space-4xl);
    text-align: center;
    min-height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.5);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
    margin-top: var(--space-3xl);
  }

  .blog-card {
    overflow: hidden;
    padding: 0;
  }

  .blog-card__image {
    width: 100%;
    height: 220px;
    object-fit: cover;
  }

  .blog-card__content {
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .blog-card__tags {
    display: flex;
    gap: var(--space-sm);
  }

  .blog-card .tag {
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .blog-card__title {
    font-size: var(--text-xl);
    color: var(--white);
  }

  .blog-card__title a {
    color: var(--white);
  }

  .blog-card__title a:hover {
    color: var(--sand);
  }

  .blog-card__excerpt {
    font-size: var(--text-sm);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.5);
  }

  .blog-card__date {
    font-size: var(--text-xs);
    margin-top: var(--space-sm);
    color: rgba(255, 255, 255, 0.35);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
