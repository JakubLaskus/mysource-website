---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';

const schemas = [
  {
    type: 'breadcrumb' as const,
    data: {
      items: [
        { name: 'Strona główna', url: 'https://www.mysource.pl/' },
        { name: 'Kontakt', url: 'https://www.mysource.pl/kontakt' },
      ],
    },
  },
];
---

<BaseLayout
  title="Kontakt - Umów spotkanie lub wypełnij formularz"
  description="Skontaktuj się z Mysource. Bezpłatna konsultacja strategiczna (30 min). Umów spotkanie lub wypełnij formularz kontaktowy."
  schemas={schemas}
>
  <!-- ════════ HERO ════════ -->
  <section class="kontakt-hero">
    <div class="container container--wide">
      <SectionHeader label="Kontakt" variant="light" />
      <h1 class="kontakt-hero__title" data-reveal-words data-reveal-delay="100">
        Porozmawiajmy<br />o przyszłości Twojej<br />organizacji
      </h1>
      <p class="kontakt-hero__desc" data-reveal data-reveal-delay="250">
        Bezpłatna konsultacja strategiczna — 30 minut, które mogą zmienić perspektywę Twojej organizacji.
      </p>
    </div>
  </section>

  <!-- ════════ CALENDLY ════════ -->
  <section class="kontakt-calendly-section" id="spotkanie">
    <div class="container container--wide">
      <SectionHeader label="Umów spotkanie" number="01" variant="dark" />
      <div class="editorial-grid">
        <div></div>
        <div>
          <p class="kontakt-calendly__desc">
            Wybierz dogodny termin na bezpłatną konsultację strategiczną. Porozmawiamy o wyzwaniach Twojej organizacji i zaproponujemy kierunek działania.
          </p>
        </div>
      </div>
      <div class="kontakt-calendly__placeholder glass-card">
        <p>Kalendarz Calendly zostanie załadowany tutaj</p>
      </div>
    </div>
  </section>

  <!-- ════════ FORM ════════ -->
  <section class="kontakt-form-section" id="formularz">
    <div class="container container--wide">
      <SectionHeader label="Formularz" number="02" variant="light" />
      <div class="kontakt-form-layout">
        <div class="kontakt-form-intro" data-reveal>
          <p class="kontakt-form__desc">
            Opisz swoje potrzeby, a my odezwiemy się w ciągu 24 godzin.
          </p>
        </div>
        <form class="kontakt-form" action="/api/contact" method="POST" data-reveal data-reveal-delay="150">
          <div class="kontakt-form__row">
            <input type="text" name="name" class="input" placeholder="Imię i nazwisko" required aria-label="Imię i nazwisko" />
            <input type="email" name="email" class="input" placeholder="Adres e-mail" required aria-label="Adres e-mail" />
          </div>
          <div class="kontakt-form__row">
            <input type="tel" name="phone" class="input" placeholder="Telefon" aria-label="Telefon" />
            <input type="text" name="company" class="input" placeholder="Firma" aria-label="Firma" />
          </div>
          <input type="text" name="role" class="input" placeholder="Stanowisko" aria-label="Stanowisko" />
          <textarea name="message" class="input" placeholder="W czym możemy pomóc?" rows="5" required aria-label="Wiadomość"></textarea>
          <label class="kontakt-form__consent">
            <input type="checkbox" name="gdpr" required />
            <span>
              Wyrażam zgodę na przetwarzanie moich danych osobowych zgodnie z
              <a href="/polityka-prywatnosci">polityką prywatności</a>.
            </span>
          </label>
          <button type="submit" class="btn btn--primary">Wyślij wiadomość</button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ─── Hero ─── */
  .kontakt-hero {
    padding-top: var(--space-5xl);
    padding-bottom: var(--space-4xl);
    background-color: var(--cream);
  }

  .kontakt-hero__title {
    font-size: var(--text-6xl);
    font-family: var(--font-display-light);
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 1.0;
    max-width: 16ch;
    margin-bottom: var(--space-xl);
  }

  .kontakt-hero__desc {
    font-size: var(--text-xl);
    color: var(--grey);
    max-width: 45ch;
    line-height: 1.6;
  }

  /* ─── Calendly (dark) ─── */
  .kontakt-calendly-section {
    padding-block: var(--space-5xl);
    background-color: var(--deep);
    color: var(--white);
  }

  .kontakt-calendly__desc {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.8;
    max-width: 55ch;
    margin-bottom: var(--space-3xl);
  }

  .kontakt-calendly__placeholder {
    padding: var(--space-4xl);
    text-align: center;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.4);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }

  /* ─── Form (light) ─── */
  .kontakt-form-section {
    padding-block: var(--space-5xl);
    background-color: var(--white);
  }

  .kontakt-form-layout {
    max-width: 700px;
  }

  .kontakt-form__desc {
    font-size: var(--text-lg);
    color: var(--grey);
    margin-bottom: var(--space-3xl);
    line-height: 1.7;
    max-width: 45ch;
  }

  .kontakt-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .kontakt-form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  .kontakt-form__consent {
    display: flex;
    gap: var(--space-sm);
    font-size: var(--text-xs);
    color: var(--grey);
    cursor: pointer;
    align-items: flex-start;
  }

  .kontakt-form__consent input {
    margin-top: 2px;
    flex-shrink: 0;
  }

  .kontakt-form__consent a {
    text-decoration: underline;
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .kontakt-form__row {
      grid-template-columns: 1fr;
    }
  }
</style>
