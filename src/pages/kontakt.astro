---
import BaseLayout from '../layouts/BaseLayout.astro';

const schemas = [
  {
    type: 'breadcrumb' as const,
    data: {
      items: [
        { name: 'Strona główna', url: 'https://www.mysource.pl/' },
        { name: 'Kontakt', url: 'https://www.mysource.pl/kontakt' },
      ],
    },
  },
];
---

<BaseLayout
  title="Kontakt - Umów spotkanie lub wypełnij formularz"
  description="Skontaktuj się z Mysource. Bezpłatna konsultacja strategiczna (30 min). Umów spotkanie lub wypełnij formularz kontaktowy."
  schemas={schemas}
>
  <!-- ════════ HERO ════════ -->
  <section class="kontakt-hero">
    <div class="container container--wide">
      <span class="label" style="color: var(--ember);" data-reveal="none">Kontakt</span>
      <h1 class="kontakt-hero__title" data-reveal-words data-reveal-delay="100">
        Bezpłatna konsultacja strategiczna (30 min)
      </h1>
      <p class="kontakt-hero__desc" data-reveal data-reveal-delay="250">
        Otrzymaj ofertę dopasowaną do swoich potrzeb.
      </p>
    </div>
  </section>

  <!-- ════════ FORM + CALENDLY ════════ -->
  <section class="kontakt-main">
    <div class="container container--wide">
      <div class="kontakt-main__grid">
        <!-- Calendly -->
        <div class="kontakt-calendly" id="spotkanie" data-reveal="left">
          <div class="kontakt-calendly__header">
            <span class="label">Umów spotkanie</span>
            <p class="kontakt-calendly__desc">
              Wybierz dogodny termin na bezpłatną konsultację strategiczną. Porozmawiamy o wyzwaniach Twojej organizacji i zaproponujemy kierunek działania.
            </p>
          </div>
          <div class="kontakt-calendly__placeholder">
            <p class="text-muted">Kalendarz Calendly zostanie załadowany tutaj</p>
          </div>
        </div>

        <!-- Form -->
        <div class="kontakt-form-wrapper" id="formularz" data-reveal="right">
          <span class="label">Wypełnij formularz</span>
          <p class="kontakt-form__desc">
            Opisz swoje potrzeby, a my odezwiemy się w ciągu 24 godzin.
          </p>
          <form class="kontakt-form" action="/api/contact" method="POST">
            <div class="kontakt-form__row">
              <input type="text" name="name" class="input" placeholder="Imię i nazwisko" required aria-label="Imię i nazwisko" />
              <input type="email" name="email" class="input" placeholder="Adres e-mail" required aria-label="Adres e-mail" />
            </div>
            <div class="kontakt-form__row">
              <input type="tel" name="phone" class="input" placeholder="Telefon" aria-label="Telefon" />
              <input type="text" name="company" class="input" placeholder="Firma" aria-label="Firma" />
            </div>
            <input type="text" name="role" class="input" placeholder="Stanowisko" aria-label="Stanowisko" />
            <textarea name="message" class="input" placeholder="W czym możemy pomóc?" rows="5" required aria-label="Wiadomość"></textarea>
            <label class="kontakt-form__consent">
              <input type="checkbox" name="gdpr" required />
              <span>
                Wyrażam zgodę na przetwarzanie moich danych osobowych przez Mysource w celu kontaktu oraz otrzymywania informacji marketingowych i sprzedażowych, w tym newslettera, za pośrednictwem środków komunikacji elektronicznej, zgodnie z obowiązującymi przepisami o ochronie danych osobowych. Zgoda jest dobrowolna i może zostać cofnięta w dowolnym momencie.
              </span>
            </label>
            <p class="kontakt-form__disclaimer">
              Klikając powyższy przycisk wyrażasz zgodę na przetwarzanie swoich danych osobowych oraz oświadczasz, że zapoznałaś/eś się z naszą <a href="/polityka-prywatnosci">Polityką Prywatności</a>. Administratorem danych osobowych jest Studio Bites spółka z ograniczoną odpowiedzialnością z siedzibą w Warszawie (KRS: 0000847684).
            </p>
            <button type="submit" class="btn btn--primary">Wyślij wiadomość</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ KONTAKT BEZPOŚREDNI ════════ -->
  <section class="kontakt-direct">
    <div class="container container--wide">
      <div class="kontakt-direct__header" data-reveal>
        <span class="label">Kontakt bezpośredni</span>
        <h2 class="kontakt-direct__title">Skontaktuj się z nami</h2>
      </div>
      <div class="kontakt-direct__grid" data-reveal-stagger>
        <a href="mailto:kontakt@mysource.pl" class="kontakt-direct__item">
          <div class="kontakt-direct__icon" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25">
              <rect x="3" y="5" width="18" height="14" rx="2" />
              <path d="M3 7l9 6 9-6" />
            </svg>
          </div>
          <span class="kontakt-direct__label font-mono">E-mail</span>
          <span class="kontakt-direct__value">kontakt@mysource.pl</span>
        </a>
        <a href="tel:+48000000000" class="kontakt-direct__item">
          <div class="kontakt-direct__icon" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
            </svg>
          </div>
          <span class="kontakt-direct__label font-mono">Telefon</span>
          <span class="kontakt-direct__value">+48 000 000 000</span>
        </a>
        <div class="kontakt-direct__item">
          <div class="kontakt-direct__icon" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
              <circle cx="12" cy="10" r="3" />
            </svg>
          </div>
          <span class="kontakt-direct__label font-mono">Adres</span>
          <span class="kontakt-direct__value">Warszawski Koneser<br />Warszawa</span>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ─── Hero ─── */
  .kontakt-hero {
    padding-top: var(--space-5xl);
    padding-bottom: var(--space-4xl);
    background-color: var(--cream);
  }

  .kontakt-hero__title {
    font-size: var(--text-5xl);
    font-family: var(--font-display-light);
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 1.05;
    max-width: 16ch;
    margin-top: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .kontakt-hero__desc {
    font-size: var(--text-xl);
    color: var(--grey);
    max-width: 45ch;
    line-height: 1.6;
  }

  /* ─── Main ─── */
  .kontakt-main {
    padding-block: var(--space-5xl);
    background-color: var(--white);
  }

  .kontakt-main__grid {
    display: grid;
    grid-template-columns: 7fr 5fr;
    gap: var(--space-4xl);
    align-items: start;
  }

  .kontakt-calendly__desc {
    font-size: var(--text-base);
    color: var(--grey);
    line-height: 1.8;
    margin-top: var(--space-md);
    margin-bottom: var(--space-xl);
    max-width: none;
  }

  .kontakt-calendly__placeholder {
    padding: var(--space-4xl);
    background: var(--grey-light);
    border-radius: var(--radius-md);
    text-align: center;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ─── Form ─── */
  .kontakt-form__desc {
    font-size: var(--text-base);
    color: var(--grey);
    margin-top: var(--space-md);
    margin-bottom: var(--space-xl);
    line-height: 1.7;
  }

  .kontakt-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .kontakt-form .input {
    font-size: var(--text-sm);
    padding: 0.7em 1em;
  }

  .kontakt-form .input::placeholder {
    font-size: var(--text-sm);
  }

  .kontakt-form textarea.input {
    font-size: var(--text-sm);
    line-height: 1.5;
  }

  .kontakt-form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  .kontakt-form__consent {
    display: flex;
    gap: var(--space-sm);
    font-size: var(--text-xs);
    color: var(--grey);
    cursor: pointer;
    align-items: flex-start;
  }

  .kontakt-form__consent input {
    margin-top: 2px;
    flex-shrink: 0;
  }

  .kontakt-form__consent a {
    text-decoration: underline;
  }

  .kontakt-form__disclaimer {
    font-size: var(--text-xs);
    color: var(--grey);
    line-height: 1.6;
    max-width: none;
    margin-top: calc(var(--space-sm) * -0.5);
  }

  .kontakt-form__disclaimer a {
    text-decoration: underline;
  }

  /* ─── Direct Contact ─── */
  .kontakt-direct {
    padding-block: var(--space-5xl);
    background-color: var(--cream);
  }

  .kontakt-direct__header {
    margin-bottom: var(--space-3xl);
  }

  .kontakt-direct__title {
    font-size: var(--text-4xl);
    margin-top: var(--space-sm);
  }

  .kontakt-direct__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .kontakt-direct__item {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-2xl);
    background: var(--white);
    border-radius: var(--radius-md);
    border: 1px solid rgba(26, 26, 25, 0.06);
    transition: box-shadow 0.3s, transform 0.3s;
  }

  a.kontakt-direct__item:hover {
    box-shadow: 0 8px 30px var(--shadow-md);
    transform: translateY(-2px);
  }

  .kontakt-direct__icon {
    color: var(--ember);
    margin-bottom: var(--space-sm);
  }

  .kontakt-direct__label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--grey);
    font-weight: 700;
  }

  .kontakt-direct__value {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--ink);
    line-height: 1.3;
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .kontakt-main__grid {
      grid-template-columns: 1fr;
    }

    .kontakt-form__row {
      grid-template-columns: 1fr;
    }

    .kontakt-direct__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
