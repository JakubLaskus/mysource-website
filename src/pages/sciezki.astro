---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import Newsletter from '../components/Newsletter.astro';
import { pathCategories } from '../data/paths';
import { curators } from '../data/team';

const curatorMap = Object.fromEntries(curators.map((c) => [c.id, c]));

const schemas = [
  {
    type: 'breadcrumb' as const,
    data: {
      items: [
        { name: 'Strona główna', url: 'https://www.mysource.pl/' },
        { name: 'Ścieżki rozwoju', url: 'https://www.mysource.pl/sciezki' },
      ],
    },
  },
  ...pathCategories.flatMap((cat) =>
    cat.paths.map((path) => ({
      type: 'course' as const,
      data: {
        name: `${path.title} - ${cat.title}`,
        description: path.description,
        url: `https://www.mysource.pl/sciezki#${path.id}`,
        courseCategory: cat.title,
        numberOfCredits: path.number,
      },
    }))
  ),
];

const sectionBgs: Record<string, string> = {
  wellbeing: 'section--sage',
  'tech-transform': 'section--white',
  leadership: 'section--mist',
};
---

<BaseLayout
  title="Ścieżki rozwoju — 10 ścieżek, 3 obszary | Mysource"
  description="Warsztaty wellbeingowe, technologiczno-transformacyjne i liderskie. 10 ścieżek współtworzonych przez ekspertów-kuratorów."
  schemas={schemas}
>
  <!-- ════════ HERO ════════ -->
  <section class="sciezki-hero">
    <div class="container container--wide">
      <span class="label" data-reveal="none">Szkolenia Mysource</span>
      <h1 class="sciezki-hero__title" data-reveal-words data-reveal-delay="100">Ścieżki rozwoju</h1>
      <div class="sciezki-hero__grid">
        <p class="sciezki-hero__lead" data-reveal data-reveal-delay="250">
          Nasze warsztaty rozwojowe realizujemy w ramach ścieżek, które obejmują kluczowe aspekty dobrostanu ludzi w organizacjach.
        </p>
        <p class="sciezki-hero__sub">
          Ścieżki współtworzone są przez ekspertów — kuratorów, którzy odpowiadają za ich treść i ramowy scenariusz.
        </p>
      </div>
    </div>
  </section>

  <!-- ════════ ŚCIEŻKI PO KATEGORIACH ════════ -->
  {pathCategories.map((cat) => (
    <section class:list={['cat-section', sectionBgs[cat.id] || '']} id={cat.id}>
      <div class="container container--wide">
        <div class="cat-section__header">
          <div class="cat-section__header-left" data-reveal="left">
            <span class="label">{cat.number}</span>
            <h2 class="cat-section__title">{cat.title}</h2>
          </div>
          <div class="cat-section__header-right" data-reveal>
            <p class="cat-section__subtitle font-display">{cat.subtitle}</p>
            <p class="cat-section__desc">{cat.description}</p>
          </div>
        </div>

        <div class="cat-section__paths" data-reveal-stagger>
          {cat.paths.map((path) => {
            const curator = curatorMap[path.curatorId];
            return (
              <div class="path-card" id={path.id}>
                <div class="path-card__top">
                  <div class="path-card__curator">
                    <img src={curator?.image || '/images/team/partner-4.png'} alt={path.curatorName} class="path-card__avatar" width="96" height="96" loading="lazy" />
                    <div>
                      <p class="path-card__curator-name">{path.curatorName}</p>
                      <p class="path-card__curator-role font-mono text-muted">
                        {curator?.role || `Kurator ścieżki ${path.title}`}
                      </p>
                    </div>
                  </div>
                </div>
                <h3 class="path-card__title">{path.title}</h3>
                <p class="path-card__desc">{path.description}</p>
              </div>
            );
          })}
        </div>
      </div>
    </section>
  ))}

  <!-- ════════ CTA ════════ -->
  <CTA variant="dark" />

  <!-- ════════ NEWSLETTER ════════ -->
  <Newsletter />
</BaseLayout>

<style>
  /* ─── Hero ─── */
  .sciezki-hero {
    padding-top: var(--space-5xl);
    padding-bottom: var(--space-4xl);
    background-color: var(--cream);
  }

  .sciezki-hero__title {
    font-size: var(--text-5xl);
    font-family: var(--font-display-light);
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin-top: var(--space-md);
    margin-bottom: var(--space-3xl);
  }

  .sciezki-hero__grid {
    display: grid;
    grid-template-columns: 7fr 5fr;
    gap: var(--space-3xl);
  }

  .sciezki-hero__lead {
    font-size: var(--text-xl);
    line-height: 1.6;
    max-width: none;
  }

  .sciezki-hero__sub {
    font-size: var(--text-base);
    line-height: 1.8;
    color: var(--grey);
    max-width: none;
  }

  /* ─── Category sections ─── */
  .cat-section {
    padding-block: var(--space-5xl);
  }

  .cat-section__header {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: var(--space-3xl);
    align-items: start;
    margin-bottom: var(--space-4xl);
  }

  .cat-section__title {
    font-size: var(--text-3xl);
    margin-top: var(--space-md);
    line-height: 1.2;
  }

  .cat-section__subtitle {
    font-size: var(--text-xl);
    font-style: italic;
    color: var(--grey);
    margin-bottom: var(--space-md);
    font-weight: 400;
    max-width: none;
  }

  .cat-section__desc {
    font-size: var(--text-base);
    color: var(--grey);
    line-height: 1.8;
    max-width: none;
  }

  /* ─── Path cards ─── */
  .cat-section__paths {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: var(--space-xl);
  }

  .path-card {
    background: var(--white);
    border-radius: var(--radius-md);
    padding: var(--space-2xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    border: 1px solid rgba(26, 26, 25, 0.06);
    transition: box-shadow 0.3s;
  }

  .path-card:hover {
    box-shadow: 0 8px 30px var(--shadow-md);
  }

  .path-card__curator {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .path-card__avatar {
    width: 96px;
    height: 96px;
    border-radius: var(--radius-full);
    background: var(--sand-light);
    flex-shrink: 0;
    object-fit: cover;
  }

  .path-card__curator-name {
    font-size: var(--text-sm);
    font-weight: 400;
  }

  .path-card__curator-role {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .path-card__title {
    font-size: var(--text-2xl);
    line-height: 1.2;
  }

  .path-card__desc {
    font-size: var(--text-sm);
    line-height: 1.7;
    color: var(--grey);
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .sciezki-hero__grid,
    .cat-section__header {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .cat-section__paths {
      grid-template-columns: 1fr;
    }
  }
</style>
