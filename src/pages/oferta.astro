---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import Newsletter from '../components/Newsletter.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CornerBrackets from '../components/CornerBrackets.astro';
import EditorialQuote from '../components/EditorialQuote.astro';
import { methods } from '../data/methods';
import { pathCategories } from '../data/paths';
import { curators } from '../data/team';

const curatorMap = Object.fromEntries(curators.map((c) => [c.id, c]));

const schemas = [
  {
    type: 'breadcrumb' as const,
    data: {
      items: [
        { name: 'Strona główna', url: 'https://www.mysource.pl/' },
        { name: 'LAB', url: 'https://www.mysource.pl/oferta' },
      ],
    },
  },
  {
    type: 'service' as const,
    data: {
      name: 'Mysource LAB - Programy szkoleniowe',
      description: 'Kompleksowe programy szkoleniowe dla pracowników i zespołów odpowiadające na wyzwania współczesnego środowiska pracy.',
      serviceType: 'Training and Development',
      url: 'https://www.mysource.pl/oferta',
      offers: methods.map((m) => ({
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: m.title,
          description: m.description,
        },
      })),
    },
  },
  ...pathCategories.flatMap((cat) =>
    cat.paths.map((path) => ({
      type: 'course' as const,
      data: {
        name: `${path.title} - ${cat.title}`,
        description: path.description,
        url: `https://www.mysource.pl/oferta#${path.id}`,
        courseCategory: cat.title,
        numberOfCredits: path.number,
      },
    }))
  ),
];

const catConfig: Record<string, { bg: string; dark: boolean; cardClass: string; headerVariant: 'light' | 'dark' }> = {
  wellbeing:        { bg: '',              dark: false, cardClass: 'path-card',            headerVariant: 'light' },
  'tech-transform': { bg: 'section--deep', dark: true,  cardClass: 'path-card glass-card', headerVariant: 'dark'  },
  leadership:       { bg: 'section--cream', dark: false, cardClass: 'path-card',            headerVariant: 'light' },
};
---

<BaseLayout
  title="LAB — Szkolenia i programy rozwojowe | Mysource"
  description="Zadbaj o rozwój i dobrostan swoich pracowników. Szkolenia wellbeingowe, technologiczno-transformacyjne i liderskie. 10 ścieżek, 30+ ekspertów."
  schemas={schemas}
>
  <!-- ════════ HERO ════════ -->
  <section class="lab-hero">
    <div class="container container--wide">
      <SectionHeader label="LAB" variant="light" />
      <h1 class="lab-hero__title" data-reveal-words data-reveal-delay="100">
        Zadbaj o rozwój i dobrostan swoich pracowników
      </h1>
      <div class="editorial-grid">
        <div></div>
        <div>
          <p class="lab-hero__lead" data-reveal data-reveal-delay="250">
            Oferujemy kompleksowe programy szkoleniowe, które realnie odpowiadają na wyzwania współczesnego środowiska pracy.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ LAB INTRO ════════ -->
  <section class="lab-intro">
    <div class="container container--wide">
      <div class="editorial-grid">
        <div></div>
        <div>
          <EditorialQuote variant="light">
            <p class="lab-intro__statement font-display" data-reveal="clip-up">
              Mysource LAB to ekosystem szkoleń i warsztatów. Wybierz ścieżkę dopasowaną do wyzwań Twojej organizacji.
            </p>
          </EditorialQuote>
          <div data-reveal-line data-reveal-delay="300" style="margin: var(--space-xl) 0; color: var(--ink);"></div>
          <p class="lab-intro__sub" data-reveal data-reveal-delay="400">
            Wychodzimy daleko poza ramy tradycyjnych szkoleń. Projektujemy angażujące, głębokie doświadczenia rozwojowe, w których solidna wiedza naukowa harmonijnie łączy się z najnowszymi metodami budowania dobrostanu.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ 3 OBSZARY ════════ -->
  <section class="areas">
    <div class="container container--wide">
      <SectionHeader label="Trzy obszary" number="01" variant="dark" />
      <div class="areas__header" data-reveal>
        <p class="areas__intro">
          Aby kompleksowo zaopiekować każdy obszar dobrostanu w Twojej organizacji, nasze szkolenia podzieliliśmy na <strong>3 kluczowe obszary</strong>:
        </p>
      </div>
      <div class="areas__grid" data-reveal-stagger>
        {pathCategories.map((cat, i) => (
          <a href={`#${cat.id}`} class="glass-card areas__card" data-hover-lift>
            <span class="areas__card-number font-mono">{String(i + 1).padStart(2, '0')}</span>
            <h2 class="areas__card-title">{cat.title}</h2>
            <p class="areas__card-subtitle font-display">{cat.subtitle}</p>
            <p class="areas__card-desc">{cat.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════ ŚCIEŻKI PO KATEGORIACH ════════ -->
  {pathCategories.map((cat) => {
    const cfg = catConfig[cat.id] || catConfig.wellbeing;
    return (
      <section class:list={['cat-section', cfg.bg]} id={cat.id}>
        {cfg.dark && <CornerBrackets />}
        <div class="container container--wide">
          <SectionHeader label={cat.title} number={cat.number} variant={cfg.headerVariant} />

          <div class="cat-section__intro editorial-grid">
            <div></div>
            <div>
              <p class:list={['cat-section__subtitle font-display', cfg.dark && 'text-light']} data-reveal>
                {cat.subtitle}
              </p>
              <p class:list={['cat-section__desc', cfg.dark && 'text-light-muted']} data-reveal data-reveal-delay="150">
                {cat.description}
              </p>
            </div>
          </div>

          <div class="cat-section__paths" data-reveal-stagger>
            {cat.paths.map((path) => {
              const curator = curatorMap[path.curatorId];
              return (
                <div class={cfg.cardClass} id={path.id}>
                  <div class="path-card__number font-mono">{path.number}</div>
                  <div class="path-card__curator">
                    <img
                      src={curator?.image || '/images/team/partner-4.png'}
                      alt={path.curatorName}
                      class="path-card__avatar"
                      width="96"
                      height="96"
                      loading="lazy"
                    />
                    <div>
                      <p class="path-card__curator-name">{path.curatorName}</p>
                      <p class="path-card__curator-role font-mono text-muted">
                        {curator?.role || `Kurator ścieżki ${path.title}`}
                      </p>
                    </div>
                  </div>
                  <h3 class="path-card__title">{path.title}</h3>
                  <p class="path-card__desc">{path.description}</p>
                  {path.videoId && (
                    <div class="path-card__video">
                      <iframe
                        src={`https://www.youtube-nocookie.com/embed/${path.videoId}?rel=0&modestbranding=1&showinfo=0&iv_load_policy=3&fs=1`}
                        title={`${path.title} — video`}
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                        allowfullscreen
                        loading="lazy"
                      ></iframe>
                    </div>
                  )}
                </div>
              );
            })}
          </div>
        </div>
      </section>
    );
  })}

  <!-- ════════ METODY ════════ -->
  <section class="metody section--photo" id="metody">
    <CornerBrackets />
    <div class="container container--wide">
      <SectionHeader label="Metody" number="04" variant="dark" />
      <div class="metody__header" data-reveal>
        <h2 class="metody__title">Metody w <em class="font-mono">my</em>source</h2>
      </div>
      <p class="metody__intro">
        W naszej ofercie znajdziesz szeroki wachlarz praktyk i metod zaprojektowanych z myślą o wspieraniu dobrostanu każdego członka organizacji.
      </p>
      <div class="metody__grid" data-reveal-stagger>
        {methods.map((method) => (
          <div class="glass-card metody__card">
            <h3 class="metody__card-title">{method.title}</h3>
            <p class="metody__card-desc">{method.description}</p>
            <ul class="metody__card-list">
              {method.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════ CTA ════════ -->
  <section class="cta-wrap">
    <div class="container container--wide">
      <SectionHeader label="Kontakt" number="05" variant="light" />
    </div>
    <CTA variant="ember" />
  </section>

  <!-- ════════ NEWSLETTER ════════ -->
  <section class="newsletter-wrap">
    <div class="container container--wide">
      <SectionHeader label="Newsletter" number="06" variant="light" />
    </div>
    <Newsletter />
  </section>
</BaseLayout>

<style>
  /* ─── Hero ─── */
  .lab-hero {
    padding-top: var(--space-5xl);
    padding-bottom: var(--space-3xl);
    background-color: var(--white);
  }

  .lab-hero__title {
    font-size: var(--text-6xl);
    font-family: var(--font-display-light);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.05;
    max-width: 18ch;
    margin-top: var(--space-md);
    margin-bottom: var(--space-3xl);
  }

  .lab-hero__lead {
    font-size: var(--text-xl);
    line-height: 1.6;
    color: var(--grey);
    max-width: 50ch;
  }

  /* ─── LAB Intro ─── */
  .lab-intro {
    padding-bottom: var(--space-5xl);
    background-color: var(--white);
  }

  .lab-intro__statement {
    font-size: var(--text-2xl);
    font-weight: 500;
    line-height: 1.45;
    color: var(--ink);
  }

  .lab-intro__sub {
    font-size: var(--text-base);
    line-height: 1.8;
    color: var(--grey);
    max-width: 55ch;
  }

  /* ─── Areas (dark) ─── */
  .areas {
    padding-block: var(--space-5xl);
    background-color: var(--deep);
    color: var(--white);
  }

  .areas__header {
    margin-bottom: var(--space-4xl);
  }

  .areas__intro {
    font-size: var(--text-xl);
    line-height: 1.6;
    max-width: 50ch;
    color: rgba(255, 255, 255, 0.7);
  }

  .areas__intro strong {
    color: var(--white);
  }

  .areas__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .areas__card {
    padding: var(--space-2xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    text-decoration: none;
  }

  .areas__card-number {
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--sand);
    line-height: 1;
  }

  .areas__card-title {
    font-size: var(--text-xl);
    margin-top: var(--space-sm);
    color: var(--white);
  }

  .areas__card-subtitle {
    font-style: italic;
    color: rgba(255, 255, 255, 0.5);
    font-size: var(--text-base);
    font-weight: 400;
  }

  .areas__card-desc {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.5);
    margin-top: var(--space-sm);
  }

  /* ─── Category sections ─── */
  .cat-section {
    position: relative;
    padding-block: var(--space-5xl);
  }

  .cat-section__intro {
    margin-bottom: var(--space-4xl);
  }

  .cat-section__subtitle {
    font-size: var(--text-xl);
    font-style: italic;
    color: var(--grey);
    margin-bottom: var(--space-md);
    font-weight: 400;
    max-width: none;
  }

  .cat-section__desc {
    font-size: var(--text-base);
    color: var(--grey);
    line-height: 1.8;
    max-width: 55ch;
  }

  .text-light {
    color: rgba(255, 255, 255, 0.85);
  }

  .text-light-muted {
    color: rgba(255, 255, 255, 0.55);
  }

  /* ─── Path cards grid ─── */
  .cat-section__paths {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: var(--space-xl);
  }

  .path-card {
    background: var(--white);
    border-radius: var(--radius-md);
    padding: var(--space-2xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    border: 1px solid rgba(26, 26, 25, 0.06);
    transition: box-shadow 0.3s, transform 0.3s;
  }

  .path-card:hover {
    box-shadow: 0 8px 30px var(--shadow-md);
    transform: translateY(-2px);
  }

  .path-card.glass-card {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
  }

  .path-card.glass-card:hover {
    border-color: var(--glass-hover-border);
  }

  .path-card.glass-card .path-card__number { color: rgba(255, 255, 255, 0.35); }
  .path-card.glass-card .path-card__curator-name { color: var(--white); }
  .path-card.glass-card .path-card__curator-role { color: rgba(255, 255, 255, 0.45); }
  .path-card.glass-card .path-card__title { color: var(--white); }
  .path-card.glass-card .path-card__desc { color: rgba(255, 255, 255, 0.65); }

  .path-card__number {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--grey);
    text-transform: uppercase;
  }

  .path-card__curator {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .path-card__avatar {
    width: 96px;
    height: 96px;
    border-radius: var(--radius-full);
    background: var(--sand-light);
    flex-shrink: 0;
    object-fit: cover;
  }

  .path-card__curator-name {
    font-size: var(--text-sm);
    font-weight: 400;
  }

  .path-card__curator-role {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .path-card__title {
    font-size: var(--text-2xl);
    line-height: 1.2;
  }

  .path-card__desc {
    font-size: var(--text-sm);
    line-height: 1.7;
    color: var(--grey);
  }

  .path-card__video {
    margin-top: auto;
    padding-top: var(--space-lg);
    aspect-ratio: 16 / 9;
    border-radius: 8px;
    overflow: hidden;
    background: var(--ink);
  }

  .path-card__video iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }

  /* ─── Metody ─── */
  .metody {
    padding-block: var(--space-5xl);
    background-color: var(--deep);
    color: var(--white);
    position: relative;
    overflow: hidden;
  }

  .metody__header {
    margin-bottom: var(--space-lg);
  }

  .metody__title {
    font-size: var(--text-4xl);
  }

  .metody__intro {
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: var(--space-4xl);
    max-width: 55ch;
    font-size: var(--text-lg);
    line-height: 1.7;
  }

  .metody__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .metody__card {
    padding: var(--space-xl);
  }

  .metody__card-title {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    font-weight: 400;
    margin-bottom: var(--space-sm);
    color: var(--white);
  }

  .metody__card-desc {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: var(--space-md);
  }

  .metody__card-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.4);
  }

  .metody__card-list li::before {
    content: '—  ';
    color: var(--sand);
  }

  /* ─── CTA / Newsletter ─── */
  .cta-wrap {
    background-color: var(--white);
    padding-top: var(--space-4xl);
  }

  .newsletter-wrap {
    background-color: var(--cream);
    padding-top: var(--space-4xl);
  }

  /* ─── Responsive ─── */
  @media (max-width: 768px) {
    .lab-hero__title {
      font-size: var(--text-4xl);
    }

    .areas__grid,
    .metody__grid {
      grid-template-columns: 1fr;
    }

    .cat-section__paths {
      grid-template-columns: 1fr;
    }
  }
</style>
