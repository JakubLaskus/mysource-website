---
interface Props {
  variant?: 'light' | 'dark';
}

const { variant = 'light' } = Astro.props;
---

<div class={`editorial-quote editorial-quote--${variant}`}>
  <span class="editorial-quote__mark" aria-hidden="true">&ldquo;</span>
  <div class="editorial-quote__content">
    <slot />
  </div>
</div>

<style>
  .editorial-quote {
    position: relative;
  }

  .editorial-quote__mark {
    position: absolute;
    top: -0.15em;
    left: -0.05em;
    font-family: var(--font-display);
    font-size: var(--text-6xl);
    line-height: 1;
    color: var(--ink);
    opacity: 0.08;
    pointer-events: none;
    user-select: none;
  }

  .editorial-quote--dark .editorial-quote__mark {
    color: var(--sand);
    opacity: 0.15;
  }

  .editorial-quote__content {
    position: relative;
    z-index: 1;
  }
</style>
