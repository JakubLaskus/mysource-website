---
const currentYear = new Date().getFullYear();

const navColumns = [
  {
    title: 'Oferta',
    links: [
      { label: 'LAB / Szkolenia', href: '/oferta' },
      { label: 'AI Readiness', href: '/o-nas' },
      { label: 'Insights', href: '/blog' },
      { label: 'Studio', href: '/studio' },
    ],
  },
  {
    title: 'Firma',
    links: [
      { label: 'Partnerzy', href: '/#partnerzy' },
      { label: 'O nas', href: '/o-nas' },
      { label: 'FAQ', href: '/faq' },
      { label: 'Kontakt', href: '/kontakt' },
    ],
  },
];
---

<footer class="footer section section--deep" role="contentinfo">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__brand">
        <img src="/images/logos/logo-mysource.webp" alt="Mysource" width="120" height="32" style="height: 28px; width: auto; filter: brightness(0) invert(1);" />
        <p class="footer__desc">
          Innowacyjny projekt wsparcia kultury wellbeingu w organizacjach oraz społeczność ekspertów praktyk rozwojowych
        </p>
        <div class="footer__social">
          <a href="https://www.instagram.com/mysource.pl/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">Instagram</a>
          <a href="https://www.linkedin.com/company/mysource-pl/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">LinkedIn</a>
        </div>
      </div>

      {navColumns.map((col) => (
        <div class="footer__col">
          <h4 class="footer__col-title">{col.title}</h4>
          <ul>
            {col.links.map((link) => (
              <li><a href={link.href} class="footer__link">{link.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="footer__bottom">
      <p>&copy; {currentYear} Mysource. Wszelkie prawa zastrzeżone.</p>
      <a href="/polityka-prywatnosci" class="footer__link">Polityka prywatności</a>
    </div>
  </div>
</footer>

<style>
  .footer__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-3xl);
    padding-bottom: var(--space-3xl);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer__desc {
    margin-top: var(--space-lg);
    font-size: var(--text-sm);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.6);
    max-width: 40ch;
  }

  .footer__social {
    display: flex;
    gap: var(--space-lg);
    margin-top: var(--space-lg);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .footer__social a {
    color: rgba(255, 255, 255, 0.6);
    transition: color 0.2s;
  }

  .footer__social a:hover {
    color: var(--ember);
  }

  .footer__col-title {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: var(--space-lg);
  }

  .footer__col ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .footer__link {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.7);
    transition: color 0.2s;
  }

  .footer__link:hover {
    color: var(--white);
  }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-xl);
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.35);
  }

  @media (max-width: 768px) {
    .footer__grid {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }

    .footer__bottom {
      flex-direction: column;
      gap: var(--space-sm);
      text-align: center;
    }
  }
</style>
