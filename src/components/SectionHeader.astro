---
interface Props {
  label: string;
  number?: string;
  variant?: 'light' | 'dark';
}

const { label, number, variant = 'light' } = Astro.props;
---

<div class={`section-header section-header--${variant}`} data-reveal-rule>
  <div class="section-header__rule"></div>
  <div class="section-header__meta">
    <span class="section-header__label">{label}</span>
    {number && <span class="section-header__number">{number}</span>}
  </div>
</div>

<style>
  .section-header {
    margin-bottom: var(--space-3xl);
  }

  .section-header__rule {
    height: 1px;
    background: var(--section-rule-color);
    margin-bottom: var(--space-md);
  }

  .section-header--dark .section-header__rule {
    background: var(--section-rule-color-light);
  }

  .section-header__meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .section-header__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--ink);
  }

  .section-header--dark .section-header__label {
    color: rgba(255, 255, 255, 0.6);
  }

  .section-header__number {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--grey);
  }

  .section-header--dark .section-header__number {
    color: rgba(255, 255, 255, 0.4);
  }
</style>
