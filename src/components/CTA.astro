---
interface Props {
  heading?: string;
  subheading?: string;
  variant?: 'light' | 'dark' | 'cream' | 'ember';
  showNote?: boolean;
}

const {
  heading = 'Gotowi na rozmowę o przyszłości waszej organizacji?',
  subheading,
  variant = 'cream',
  showNote = true,
} = Astro.props;

const sectionClassMap: Record<string, string> = {
  dark: 'section--deep',
  cream: 'section--cream',
  ember: 'section--ember',
  light: '',
};
const sectionClass = sectionClassMap[variant] || '';
const isDark = variant === 'dark';
---

<section class:list={['section cta', sectionClass]}>
  <div class="container cta__inner" data-reveal>
    <span class="label cta__label">Kontakt</span>
    <h2 class="cta__heading">{heading}</h2>
    {subheading && <p class="cta__sub">{subheading}</p>}
    <div class="cta__actions">
      <a href="/kontakt#spotkanie" class:list={['btn', isDark ? 'btn--primary' : 'btn--primary']}>
        Umów spotkanie
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      <a href="/kontakt#formularz" class:list={['btn', isDark ? 'btn--white' : 'btn--outline']}>
        Wypełnij formularz
      </a>
    </div>
    {showNote && (
      <div class="cta__notes">
        <p class="cta__note">Bezpłatna konsultacja strategiczna (30 min)</p>
        <p class="cta__note">Otrzymaj ofertę dopasowaną do swoich potrzeb</p>
      </div>
    )}
  </div>
</section>

<style>
  .cta {
    padding-block: var(--space-5xl);
  }

  .cta__inner {
    text-align: center;
    max-width: 780px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2xl);
  }

  .cta__label {
    display: inline-block;
    color: var(--ember);
    margin-bottom: var(--space-md);
  }

  .cta__heading {
    font-size: var(--text-4xl);
    line-height: 1.15;
    max-width: 20ch;
    margin-inline: auto;
  }

  .cta__sub {
    color: var(--grey);
    font-size: var(--text-lg);
    line-height: 1.6;
    margin-inline: auto;
    max-width: 50ch;
  }

  .cta__actions {
    display: flex;
    justify-content: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
    margin-top: var(--space-md);
  }

  .cta__notes {
    display: flex;
    justify-content: center;
    flex-direction: column;
    gap: var(--space-sm);
    margin-top: var(--space-lg);
  }

  .cta__note {
    font-size: var(--text-sm);
    color: var(--grey);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .section--deep .cta__label {
    color: var(--sand);
  }

  .section--deep .cta__note {
    color: rgba(255, 255, 255, 0.5);
  }

  @media (max-width: 768px) {
    .cta {
      padding-block: var(--space-4xl);
    }

    .cta__inner {
      gap: var(--space-xl);
    }

    .cta__heading {
      font-size: var(--text-3xl);
    }
  }
</style>
