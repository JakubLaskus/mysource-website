---
interface Props {
  color?: string;
}

const { color } = Astro.props;
---

<div class="corner-brackets" style={color ? `--bracket-c: ${color}` : undefined} data-reveal="bracket">
  <span class="corner-brackets__tl"></span>
  <span class="corner-brackets__tr"></span>
  <span class="corner-brackets__bl"></span>
  <span class="corner-brackets__br"></span>
</div>

<style>
  .corner-brackets {
    position: absolute;
    inset: var(--bracket-inset);
    z-index: 2;
    pointer-events: none;
  }

  .corner-brackets__tl,
  .corner-brackets__tr,
  .corner-brackets__bl,
  .corner-brackets__br {
    position: absolute;
    width: var(--bracket-size);
    height: var(--bracket-size);
  }

  .corner-brackets__tl {
    top: 0;
    left: 0;
    border-top: var(--bracket-stroke) solid var(--bracket-c, var(--bracket-color));
    border-left: var(--bracket-stroke) solid var(--bracket-c, var(--bracket-color));
  }

  .corner-brackets__tr {
    top: 0;
    right: 0;
    border-top: var(--bracket-stroke) solid var(--bracket-c, var(--bracket-color));
    border-right: var(--bracket-stroke) solid var(--bracket-c, var(--bracket-color));
  }

  .corner-brackets__bl {
    bottom: 0;
    left: 0;
    border-bottom: var(--bracket-stroke) solid var(--bracket-c, var(--bracket-color));
    border-left: var(--bracket-stroke) solid var(--bracket-c, var(--bracket-color));
  }

  .corner-brackets__br {
    bottom: 0;
    right: 0;
    border-bottom: var(--bracket-stroke) solid var(--bracket-c, var(--bracket-color));
    border-right: var(--bracket-stroke) solid var(--bracket-c, var(--bracket-color));
  }

  @media (max-width: 480px) {
    .corner-brackets {
      display: none;
    }
  }
</style>
